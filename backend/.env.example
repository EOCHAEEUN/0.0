OPENROUTER_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Local HTTP development. If omitted, HTTPS frontend origins enable this automatically.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_ACCESS_COOKIE_MAX_AGE=3600
AUTH_REFRESH_COOKIE_MAX_AGE=2592000
MAX_REQUEST_BODY_BYTES=1048576
AUTH_LOGIN_ATTEMPTS_PER_MINUTE=5
AUTH_EMAIL_CODE_REQUESTS_PER_MINUTE=3
AUTH_EMAIL_CODE_VERIFICATIONS_PER_MINUTE=10
AUTH_REFRESH_REQUESTS_PER_MINUTE=30
EXPENSIVE_API_REQUESTS_PER_MINUTE=10
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Production must use HTTPS and set AUTH_COOKIE_SECURE=true.
